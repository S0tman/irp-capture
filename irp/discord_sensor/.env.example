# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# IRP Project Root
# Path to the IRP project directory
IRP_PROJECT_ROOT=/Users/jolopes/irp-capture

# Optional: Discord Guild ID (for slash command syncing)
DISCORD_GUILD_ID=0

# MacPorts Python SSL Certificate Fix (macOS development only)
# If running on macOS with MacPorts Python and getting SSL certificate errors:
# 1. Activate the venv: source venv/bin/activate
# 2. Install certifi: pip install certifi
# 3. Run the bot with: SSL_CERT_FILE=$(python3 -c 'import certifi; print(certifi.where())') python -m irp.discord_sensor.main
#
# Or set this variable in your .env (uncomment the line below and update the path):
# SSL_CERT_FILE=/Users/jolopes/irp-capture/irp/discord_sensor/venv/lib/python3.11/site-packages/certifi/cacert.pem

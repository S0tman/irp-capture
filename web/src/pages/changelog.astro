---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Changelog from '../../../CHANGELOG.md';

const { headings } = await Changelog.getHeadings?.() ?? { headings: [] };
---

<BaseLayout title="Changelog | IRP" description="Release history for irp-capture — version notes, new features, and fixes.">
  <ReadingProgress />
  <Header currentSlug="changelog" />

  <div id="chapter-layout" class="flex max-w-[90rem] mx-auto">
    <Sidebar currentSlug="changelog" />

    <main class="flex-1 min-w-0 px-4 md:px-8 lg:px-12 py-8 transition-all duration-200">
      <article class="chapter-prose">
        <Changelog />
      </article>
    </main>

    <TableOfContents headings={[]} />
  </div>

  <script src="../scripts/copy-code.ts"></script>
  <script src="../scripts/focus-mode.ts"></script>
</BaseLayout>

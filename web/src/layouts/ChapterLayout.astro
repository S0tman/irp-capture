---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ChapterNav from '../components/ChapterNav.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import InteractiveDiagrams from '../components/InteractiveDiagrams.astro';
import { type ChapterConfig, type PartConfig, isFirstChapterOfPart } from '../book.config';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  chapterNumber: number;
  slug: string;
  headings: Heading[];
  prev: ChapterConfig | null;
  next: ChapterConfig | null;
  part: PartConfig | undefined;
}

const { title, description, chapterNumber, slug, headings, prev, next, part } = Astro.props;
const showPartHeader = part && isFirstChapterOfPart(chapterNumber);
---

<BaseLayout title={`Ch ${chapterNumber}. ${title} | IRP`} description={description}>
  <ReadingProgress />
  <Header />

  <div id="chapter-layout" class="flex max-w-[90rem] mx-auto">
    <Sidebar currentSlug={slug} />

    <main class="flex-1 min-w-0 px-4 md:px-8 lg:px-12 py-8 transition-all duration-200">
      {showPartHeader && (
        <div class="mb-8 pb-6 border-b border-[var(--color-border)] dark:border-[#333]">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-terracotta)] mb-1">Part {part!.number}</p>
          <h2 class="text-2xl font-bold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] font-[var(--font-serif)]">{part!.title}</h2>
          <p class="text-sm italic text-[var(--color-muted)] mt-2">{part!.epigraph}</p>
        </div>
      )}

      <article class="chapter-prose">
        <slot />
      </article>

      <InteractiveDiagrams chapterNumber={chapterNumber} />

      <ChapterNav prev={prev} next={next} />
    </main>

    <TableOfContents headings={headings} />
  </div>

  <!-- Client-side scripts -->
  <script src="../scripts/copy-code.ts"></script>
  <script src="../scripts/focus-mode.ts"></script>

  <!-- Mermaid diagram rendering — finds code blocks with mermaid content -->
  <script>
    import mermaid from 'mermaid';

    // Mermaid directives that identify a code block as a mermaid diagram
    const MERMAID_PREFIXES = [
      'graph ', 'graph\n', 'flowchart ', 'flowchart\n',
      'sequenceDiagram', 'classDiagram', 'stateDiagram',
      'erDiagram', 'gantt', 'pie ', 'pie\n', 'gitGraph',
      'mindmap', 'timeline', 'sankey', 'xychart',
    ];

    function isMermaidSource(text: string): boolean {
      const trimmed = text.trim();
      return MERMAID_PREFIXES.some(p => trimmed.startsWith(p));
    }

    let renderSeq = 0;

    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    async function renderAll() {
      mermaid.initialize({
        startOnLoad: false,
        theme: isDark() ? 'dark' : 'neutral',
        securityLevel: 'loose',
        fontFamily: 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
      });

      // Find all <pre> blocks and check if their text is mermaid source.
      // The remark plugin relabels ```mermaid to ```plaintext so Shiki
      // renders them as plain code blocks. We detect by content.
      const allPre = document.querySelectorAll<HTMLElement>('pre');
      for (const pre of allPre) {
        // Skip already-processed blocks
        if (pre.dataset.mermaidRendered) continue;

        const code = pre.querySelector('code');
        if (!code) continue;

        const source = code.textContent || '';
        if (!isMermaidSource(source)) continue;

        pre.dataset.mermaidSource = source;
        pre.dataset.mermaidRendered = 'true';

        const id = `mermaid-${++renderSeq}`;
        try {
          const { svg } = await mermaid.render(id, source);
          const container = document.createElement('div');
          container.className = 'mermaid-rendered overflow-x-auto py-4';
          container.dataset.mermaidSource = source;
          container.innerHTML = svg;
          pre.replaceWith(container);
        } catch (e) {
          console.warn('[mermaid] render error:', e);
          // Leave the code block visible as fallback
        }
      }

      // Re-render already-rendered diagrams on theme change
      const rendered = document.querySelectorAll<HTMLElement>('.mermaid-rendered');
      for (const container of rendered) {
        const source = container.dataset.mermaidSource;
        if (!source) continue;
        const id = `mermaid-re-${++renderSeq}`;
        try {
          const { svg } = await mermaid.render(id, source);
          container.innerHTML = svg;
        } catch (e) {
          console.warn('[mermaid] re-render error:', e);
        }
      }
    }

    renderAll();
    window.addEventListener('theme-changed', renderAll);
  </script>
</BaseLayout>

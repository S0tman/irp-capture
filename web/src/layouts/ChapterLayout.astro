---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ChapterNav from '../components/ChapterNav.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import InteractiveDiagrams from '../components/InteractiveDiagrams.astro';
import { type ChapterConfig, type PartConfig, isFirstChapterOfPart } from '../book.config';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  chapterNumber: number;
  slug: string;
  headings: Heading[];
  prev: ChapterConfig | null;
  next: ChapterConfig | null;
  part: PartConfig | undefined;
}

const { title, description, chapterNumber, slug, headings, prev, next, part } = Astro.props;
const showPartHeader = part && isFirstChapterOfPart(chapterNumber);
---

<BaseLayout title={`Ch ${chapterNumber}. ${title} | IRP`} description={description}>
  <ReadingProgress />
  <Header />

  <div id="chapter-layout" class="flex max-w-[90rem] mx-auto">
    <Sidebar currentSlug={slug} />

    <main class="flex-1 min-w-0 px-4 md:px-8 lg:px-12 py-8 transition-all duration-200">
      {showPartHeader && (
        <div class="mb-8 pb-6 border-b border-[var(--color-border)] dark:border-[#333]">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-terracotta)] mb-1">Part {part!.number}</p>
          <h2 class="text-2xl font-bold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] font-[var(--font-serif)]">{part!.title}</h2>
          <p class="text-sm italic text-[var(--color-muted)] mt-2">{part!.epigraph}</p>
        </div>
      )}

      <article class="chapter-prose">
        <slot />
      </article>

      <InteractiveDiagrams chapterNumber={chapterNumber} />

      <ChapterNav prev={prev} next={next} />
    </main>

    <TableOfContents headings={headings} />
  </div>

  <!-- Client-side scripts -->
  <script src="../scripts/copy-code.ts"></script>
  <script src="../scripts/focus-mode.ts"></script>

  <!-- Mermaid diagram rendering (CDN ESM — no bundler required) -->
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

    function getMermaidTheme() {
      return document.documentElement.classList.contains('dark') ? 'dark' : 'neutral';
    }

    async function renderMermaidDiagrams() {
      mermaid.initialize({
        startOnLoad: false,
        theme: getMermaidTheme(),
        securityLevel: 'loose',
        fontFamily: 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
      });

      const wrappers = document.querySelectorAll('.mermaid-wrapper');
      for (const wrapper of wrappers) {
        // Skip slots that already have a React component teleported in
        if (wrapper.querySelector('.diagram-source')) continue;
        // Skip already-rendered diagrams (avoid double render on theme change)
        if (wrapper.querySelector('.mermaid-rendered')) {
          wrapper.innerHTML = '';
        }

        const tmpl = wrapper.querySelector('template.mermaid-src');
        if (!tmpl) continue;

        // Decode HTML entities preserved by the remark plugin
        const decoded = tmpl.innerHTML
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/&amp;/g, '&');

        const id = `mermaid-${wrapper.getAttribute('data-diagram-index') ?? Math.random().toString(36).slice(2)}`;

        try {
          const { svg } = await mermaid.render(id, decoded);
          wrapper.innerHTML = `<div class="mermaid-rendered overflow-x-auto py-2">${svg}</div>`;
        } catch (e) {
          console.warn('Mermaid render error (slot', wrapper.getAttribute('data-diagram-index'), '):', e);
          wrapper.innerHTML = `<pre class="overflow-x-auto p-4 rounded-lg text-sm opacity-60">${tmpl.innerHTML}</pre>`;
        }
      }
    }

    // module scripts are deferred — runs after page parse and React teleport
    renderMermaidDiagrams();

    // Re-render when theme toggles
    window.addEventListener('theme-changed', renderMermaidDiagrams);
  </script>
</BaseLayout>

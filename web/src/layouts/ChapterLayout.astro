---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ChapterNav from '../components/ChapterNav.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import InteractiveDiagrams from '../components/InteractiveDiagrams.astro';
import { type ChapterConfig, type PartConfig, isFirstChapterOfPart } from '../book.config';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  chapterNumber: number;
  slug: string;
  headings: Heading[];
  prev: ChapterConfig | null;
  next: ChapterConfig | null;
  part: PartConfig | undefined;
}

const { title, description, chapterNumber, slug, headings, prev, next, part } = Astro.props;
const showPartHeader = part && isFirstChapterOfPart(chapterNumber);
---

<BaseLayout title={`Ch ${chapterNumber}. ${title} | IRP`} description={description}>
  <ReadingProgress />
  <Header />

  <div id="chapter-layout" class="flex max-w-[90rem] mx-auto">
    <Sidebar currentSlug={slug} />

    <main class="flex-1 min-w-0 px-4 md:px-8 lg:px-12 py-8 transition-all duration-200">
      {showPartHeader && (
        <div class="mb-8 pb-6 border-b border-[var(--color-border)] dark:border-[#333]">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-terracotta)] mb-1">Part {part!.number}</p>
          <h2 class="text-2xl font-bold text-[var(--color-charcoal)] dark:text-[var(--color-cream)] font-[var(--font-serif)]">{part!.title}</h2>
          <p class="text-sm italic text-[var(--color-muted)] mt-2">{part!.epigraph}</p>
        </div>
      )}

      <article class="chapter-prose">
        <slot />
      </article>

      <InteractiveDiagrams chapterNumber={chapterNumber} />

      <ChapterNav prev={prev} next={next} />
    </main>

    <TableOfContents headings={headings} />
  </div>

  <!-- Client-side scripts -->
  <script src="../scripts/copy-code.ts"></script>
  <script src="../scripts/focus-mode.ts"></script>

  <!-- Mermaid diagram rendering — bundled via Vite, no CDN required -->
  <script>
    import mermaid from 'mermaid';

    let renderSeq = 0;

    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    async function renderAll() {
      mermaid.initialize({
        startOnLoad: false,
        theme: isDark() ? 'dark' : 'neutral',
        securityLevel: 'loose',
        fontFamily: 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
      });

      const wrappers = document.querySelectorAll<HTMLElement>('.mermaid-wrapper');
      for (const wrapper of wrappers) {
        // Skip slots where a React component has been teleported in
        if (wrapper.querySelector('.diagram-source')) continue;

        // Decode source from base64 attr (set by remark-mermaid-raw.mjs)
        // Cache on dataset so we can re-render after theme change without the attr
        let source = wrapper.dataset.mermaidSource;
        if (!source) {
          const b64 = wrapper.getAttribute('data-mermaid-b64');
          if (!b64) continue;
          try {
            source = atob(b64);
            wrapper.dataset.mermaidSource = source;
          } catch (e) {
            console.warn('[mermaid] base64 decode failed on slot', wrapper.dataset.diagramIndex, e);
            continue;
          }
        }

        wrapper.innerHTML = '';
        const id = `mermaid-${wrapper.dataset.diagramIndex ?? 'x'}-${++renderSeq}`;
        try {
          const { svg } = await mermaid.render(id, source);
          wrapper.innerHTML = `<div class="overflow-x-auto py-4">${svg}</div>`;
        } catch (e) {
          console.warn('[mermaid] render error on slot', wrapper.dataset.diagramIndex, e);
          wrapper.innerHTML = `<pre class="overflow-x-auto p-4 rounded-lg text-sm opacity-60">${source}</pre>`;
        }
      }
    }

    // Astro module scripts are deferred — runs after DOM is ready
    renderAll();

    // Re-render when theme toggles
    window.addEventListener('theme-changed', renderAll);
  </script>
</BaseLayout>
